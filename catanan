**3. Endpoint yang Dibutuhkan (dari kode frontend)**

Berdasarkan semua halaman yang sudah dibuat, backend perlu menyediakan:
```
GET  /api/menu/user/:cafe_id        → daftar menu
GET  /api/kategori/user/:cafe_id    → daftar kategori
GET  /api/pengaturan/user/:cafe_id  → profil + tema cafe
GET  /api/orders?meja=&cafe_id=     → riwayat pesanan per meja
POST /api/orders                    → buat pesanan baru
PATCH /api/orders/:id/status        → update status pesanan
4. Struktur Tabel Database

sql
-- Cafe / pengaturan
CREATE TABLE cafe (
  id INT PRIMARY KEY AUTO_INCREMENT,
  nama_cafe VARCHAR(100),
  alamat TEXT,
  logo VARCHAR(255),
  jam_buka VARCHAR(50),
  tema_colors JSON,   -- {"primary":"#f59e0b","secondary":"#ea580c","bg":"#f9fafb","text":"#111827"}
  tagline TEXT
);

-- Kategori menu
CREATE TABLE kategori (
  id INT PRIMARY KEY AUTO_INCREMENT,
  cafe_id INT,
  nama_kategori VARCHAR(100),
  logo VARCHAR(255)
);

-- Menu
CREATE TABLE menu (
  id INT PRIMARY KEY AUTO_INCREMENT,
  cafe_id INT,
  category_id INT,
  name VARCHAR(100),
  harga DECIMAL(10,2),
  harga_asli DECIMAL(10,2),
  deskripsi TEXT,
  foto VARCHAR(255),
  badge VARCHAR(50),
  discount VARCHAR(20),
  is_vegan BOOLEAN DEFAULT 0,
  kalori INT,
  waktu_masak VARCHAR(50),
  volume VARCHAR(50)
);

-- Orders
CREATE TABLE orders (
  id VARCHAR(20) PRIMARY KEY,
  cafe_id INT,
  meja INT,
  nama VARCHAR(100),
  status ENUM('proses','selesai') DEFAULT 'proses',
  total DECIMAL(10,2),
  note TEXT,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Order items
CREATE TABLE order_items (
  id INT PRIMARY KEY AUTO_INCREMENT,
  order_id VARCHAR(20),
  nama_menu VARCHAR(100),
  qty INT,
  harga DECIMAL(10,2)
);
